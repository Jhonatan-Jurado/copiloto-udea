# Copiar este archivo como .env y completar las rutas según tu sistema
# NUNCA subas el .env a GitHub

# ─── OCR ───────────────────────────────────────────────────────────────────────
# Tesseract — descargar instalador desde:
# https://github.com/UB-Mannheim/tesseract/wiki
# Durante la instalación marcar idioma: Spanish (spa)
#
# Windows (ruta típica con instalador de usuario):
TESSERACT_PATH=C:\Users\TU_USUARIO\AppData\Local\Programs\Tesseract-OCR\tesseract.exe
# Windows (ruta típica con instalador global):
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Poppler — descargar ZIP desde:
# https://github.com/oschwartz10612/poppler-windows/releases
# Extraer en C:\poppler\ y ajustar la ruta según la versión descargada
POPPLER_PATH=C:\poppler\Release-26.02.0-0\poppler-26.02.0\Library\bin

# ─── LLM ───────────────────────────────────────────────────────────────────────

